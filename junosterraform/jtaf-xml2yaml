#!/usr/bin/env python3
import argparse
import copy
import json
import os
import re
import shutil
import yaml
from xml.etree import ElementTree
from typing import Any, Optional


_OMIT = object()


def prepare_tag(tag: str) -> str:
    """Prepare XML tag to be used as YAML key by replacing '-' and '.' with '_'."""
    return tag.replace("-", "_").replace(".", "_")


def detect_device_type(xml_dict: dict[str, Any]) -> Optional[str]:
    """Detect device type from configuration (e.g., 'qfx', 'srx', 'mx').

    Looks for device model or version hints in system/product-name or chassis.
    """
    # Check system.product_name
    if "system" in xml_dict and isinstance(xml_dict["system"], dict):
        product_name = xml_dict["system"].get("product_name", "").lower()
        if product_name:
            # Extract device type from product name (e.g., "Juniper Networks QFX5100" -> "qfx")
            for device_type in ["qfx", "srx", "mx", "ptx", "acx", "ex"]:
                if device_type in product_name:
                    return device_type

    # Check chassis.product_name
    if "chassis" in xml_dict and isinstance(xml_dict["chassis"], dict):
        product_name = xml_dict["chassis"].get("product_name", "").lower()
        if product_name:
            for device_type in ["qfx", "srx", "mx", "ptx", "acx", "ex"]:
                if device_type in product_name:
                    return device_type

    return None


def element_node(
    element: ElementTree.Element,
    path: str,
    resources: dict[str, Any],
):
    """Return the resource node matching the given XML element and path.

    Args:
        element: XML element to match.
        path: Path to match in the schema.
        resources: Schema resource node to search.

    Returns:
        The matching resource node or None if not found.
    """

    if resources["name"] == element.tag and (
        resources.get("path") is None or (resources["path"] + "/" + element.tag) == path
    ):
        return {k: v for k, v in resources.items() if k != "children"}

    try:
        for elem in resources["children"]:
            matched_type = element_node(element, path, elem)
            if matched_type:
                return matched_type
    except KeyError:
        return None

    return None


def elem_to_dict(
    element: ElementTree.Element,
    path: str,
    resources: Any,
) -> dict[str, Any]:
    """Convert an XML element and its children to a dictionary.

    Args:
        element: XML element to convert.
        path: Current path of the element. Needed to uniquely identify the
            element in the schema.
        resources: Schema resource node to use for type information.

    Returns:
        A dictionary representation of the XML element.
    """

    result = {}
    for child in element:
        prepared_tag = prepare_tag(child.tag)
        prepared_path = child.tag
        if len(path) > 0:
            prepared_path = path + "/" + child.tag
        resource_node = element_node(child, prepared_path, resources)
        elem_type = resource_node["type"] if resource_node else None

        if elem_type == "list":
            # If the element is of type list, always create a list
            if not result.get(prepared_tag):
                result[prepared_tag] = []
            if len(child) > 0:
                result[prepared_tag].append(
                    elem_to_dict(child, prepared_path, resources)
                )
            else:
                result[prepared_tag].append(child.text)
        elif elem_type == "leaf-list":
            # If the element is of type leaf-list, always create a list
            result[prepared_tag] = child.text
        elif elem_type == "container":
            # If the element is of type container, always create a dict
            if len(child) > 0:
                result[prepared_tag] = elem_to_dict(child, prepared_path, resources)
            else:
                result[prepared_tag] = ""
        else:
            # For other types, decide based on children
            if len(child) > 0:
                result[prepared_tag] = elem_to_dict(child, prepared_path, resources)
            else:
                if elem_type == "leaf":
                    if not child.text:
                        result[prepared_tag] = True
                    else:
                        result[prepared_tag] = child.text
                else:
                    result[prepared_tag] = child.text
    return result


META_KEY = "meta"
REGISTRY_KEY = "jtaf_registry"
PROVIDERS_KEY = "providers"
ALL_YAML = "all.yaml"
ALL_YML = "all.yml"


def _plain_group_name(name: str) -> str:
    """Return plain group name from an internal token."""
    if ":" in name:
        return name.split(":", 1)[1]
    return name


def _is_scalar(value: Any) -> bool:
    return not isinstance(value, (dict, list))


def _value_key(value: Any) -> str:
    try:
        return json.dumps(value, sort_keys=True)
    except TypeError:
        return str(value)


def _infer_identity_key_for_dict_lists(
    dict_lists: list[list[dict[str, Any]]],
) -> Optional[str]:
    """Infer a stable identity key shared across list-of-dict payloads."""
    non_empty = [lst for lst in dict_lists if lst]
    if not non_empty:
        return None

    common_keys = set(non_empty[0][0].keys())
    for lst in non_empty:
        for item in lst:
            if not isinstance(item, dict):
                return None
            common_keys &= set(item.keys())

    preferred = ["name", "id", "key", "uuid"]
    ordered = [key for key in preferred if key in common_keys]
    ordered.extend(sorted(key for key in common_keys if key not in preferred))

    for candidate in ordered:
        valid = True
        for lst in non_empty:
            seen: set[str] = set()
            for item in lst:
                if candidate not in item:
                    valid = False
                    break
                key_val = item[candidate]
                if (
                    key_val is None
                    or not _is_scalar(key_val)
                    or isinstance(key_val, bool)
                ):
                    valid = False
                    break
                token = _value_key(key_val)
                if token in seen:
                    valid = False
                    break
                seen.add(token)
            if not valid:
                break

        if valid:
            return candidate

    return None


def _as_keyed_list_map(
    items: list[dict[str, Any]],
    key_name: str,
) -> tuple[dict[str, dict[str, Any]], list[str]]:
    """Convert list-of-dicts into token map and stable token order."""
    mapping: dict[str, dict[str, Any]] = {}
    order: list[str] = []

    for item in items:
        token = _value_key(item[key_name])
        mapping[token] = item
        order.append(token)

    return mapping, order


def intersect_values(left: Any, right: Any):
    """Return shared structure/value between two objects.

    Dicts are intersected recursively by key. Lists/scalars are shared only
    when exactly equal, except keyed list-of-dicts which are intersected by key.
    """
    if type(left) is not type(right):
        return _OMIT

    if isinstance(left, dict):
        common = {}
        for key in left.keys() & right.keys():
            shared_value = intersect_values(left[key], right[key])
            if shared_value is not _OMIT:
                common[key] = shared_value
        return common

    if isinstance(left, list):
        if left == right:
            return copy.deepcopy(left)

        if left and right and all(isinstance(item, dict) for item in left + right):
            key_name = _infer_identity_key_for_dict_lists([
                [item for item in left if isinstance(item, dict)],
                [item for item in right if isinstance(item, dict)],
            ])
            if key_name:
                left_map, left_order = _as_keyed_list_map(left, key_name)
                right_map, _ = _as_keyed_list_map(right, key_name)
                shared_items: list[dict[str, Any]] = []
                for token in left_order:
                    if token not in right_map:
                        continue
                    shared_value = intersect_values(left_map[token], right_map[token])
                    if isinstance(shared_value, dict) and shared_value:
                        shared_items.append(shared_value)
                return shared_items if shared_items else _OMIT

        return _OMIT

    return copy.deepcopy(left) if left == right else _OMIT


def subtract_common(value: Any, common: Any):
    """Return value with shared structure removed recursively."""
    if common is _OMIT:
        return copy.deepcopy(value)

    if type(value) is not type(common):
        return copy.deepcopy(value)

    if isinstance(value, dict):
        delta = {}
        for key, item in value.items():
            if key in common:
                stripped = subtract_common(item, common[key])
                if stripped is not _OMIT:
                    delta[key] = stripped
            else:
                delta[key] = copy.deepcopy(item)
        return delta if delta else _OMIT

    if isinstance(value, list):
        if value == common:
            return _OMIT

        if value and common and all(isinstance(item, dict) for item in value + common):
            key_name = _infer_identity_key_for_dict_lists([
                [item for item in value if isinstance(item, dict)],
                [item for item in common if isinstance(item, dict)],
            ])
            if key_name:
                common_map, _ = _as_keyed_list_map(common, key_name)
                delta_items: list[Any] = []
                for item in value:
                    token = _value_key(item[key_name])
                    if token not in common_map:
                        delta_items.append(copy.deepcopy(item))
                        continue
                    stripped = subtract_common(item, common_map[token])
                    if stripped is _OMIT:
                        continue
                    if isinstance(stripped, dict) and key_name not in stripped:
                        stripped[key_name] = copy.deepcopy(item[key_name])
                    delta_items.append(stripped)
                return delta_items if delta_items else _OMIT

        return copy.deepcopy(value)

    return _OMIT if value == common else copy.deepcopy(value)


def build_shared_payload(host_payloads: list[dict[str, Any]]) -> dict[str, Any]:
    """Build one shared dictionary from all host payload dictionaries."""
    if not host_payloads:
        return {}
    shared = copy.deepcopy(host_payloads[0])
    for payload in host_payloads[1:]:
        shared = intersect_values(shared, payload)
        if shared is _OMIT:
            return {}
    if isinstance(shared, dict):
        return shared
    return {}


def build_group_shared_payload(payloads: list[dict[str, Any]]) -> dict[str, Any]:
    """Build shared payload from a subset of hosts."""
    return build_shared_payload(payloads)


def _collect_paths(value: Any, prefix: str = "") -> set[str]:
    """Collect structural dotted paths present in payload for signature grouping."""
    paths: set[str] = set()

    if isinstance(value, dict):
        for key, nested in value.items():
            if key == META_KEY or key.startswith("_merge"):
                continue
            next_prefix = f"{prefix}.{key}" if prefix else key
            paths.add(next_prefix)
            paths |= _collect_paths(nested, next_prefix)
    elif isinstance(value, list):
        list_prefix = f"{prefix}[]" if prefix else "[]"
        paths.add(list_prefix)
        for item in value:
            if isinstance(item, (dict, list)):
                paths |= _collect_paths(item, list_prefix)

    return paths


def payload_signature(payload: dict[str, Any]) -> tuple[str, ...]:
    """Build deterministic structural signature from filtered payload paths."""
    return tuple(sorted(_collect_paths(payload)))


def _collect_leaf_path_values(
    value: Any,
    prefix: tuple[str, ...] = (),
) -> dict[tuple[str, ...], Any]:
    """Collect leaf path values from nested payloads for support counting."""
    result: dict[tuple[str, ...], Any] = {}

    if isinstance(value, dict):
        for key, nested in value.items():
            if key == META_KEY or key.startswith("_merge"):
                continue
            result.update(_collect_leaf_path_values(nested, prefix + (key,)))
        return result

    if isinstance(value, list):
        if value and all(isinstance(item, dict) for item in value):
            key_name = _infer_identity_key_for_dict_lists([
                [item for item in value if isinstance(item, dict)],
            ])
            if key_name:
                for item in value:
                    key_token = _value_key(item[key_name])
                    item_prefix = prefix + (f"[{key_name}={key_token}]",)
                    result.update(_collect_leaf_path_values(item, item_prefix))
                return result

        result[prefix] = copy.deepcopy(value)
        return result

    result[prefix] = copy.deepcopy(value)
    return result


def _leaf_count(value: Any) -> int:
    """Count leaf values in nested payload for reuse scoring."""
    if isinstance(value, dict):
        return sum(_leaf_count(item) for item in value.values())
    if isinstance(value, list):
        return sum(_leaf_count(item) for item in value)
    return 1


def sanitize_group_name(name: str) -> str:
    """Normalize group names for inventory and filesystem safety."""
    sanitized = re.sub(r"[^a-zA-Z0-9_]+", "_", name.strip().lower()).strip("_")
    return sanitized or "common"


def compact_payload(value: Any):
    """Recursively remove empty dict/list branches from payloads."""
    if isinstance(value, dict):
        compacted: dict[str, Any] = {}
        for key, nested in value.items():
            cleaned = compact_payload(nested)
            if cleaned is not _OMIT:
                compacted[key] = cleaned
        return compacted if compacted else _OMIT

    if isinstance(value, list):
        compacted_list = []
        for item in value:
            cleaned = compact_payload(item)
            if cleaned is not _OMIT:
                compacted_list.append(cleaned)
        return compacted_list if compacted_list else _OMIT

    return copy.deepcopy(value)


def remove_merge_meta_keys(value: Any) -> Any:
    """Recursively remove merge and meta keys from payload math."""
    if isinstance(value, dict):
        cleaned: dict[str, Any] = {}
        for key, nested in value.items():
            if key == META_KEY or key.startswith("_merge"):
                continue
            cleaned[key] = remove_merge_meta_keys(nested)
        return cleaned
    if isinstance(value, list):
        return [remove_merge_meta_keys(item) for item in value]
    return copy.deepcopy(value)


def apply_merge_directive_hints(
    override: Any,
    baseline: Any,
    profile: str,
    list_strategy_default: str,
) -> Any:
    """Annotate override payload with merge directives according to profile."""
    if profile == "off":
        return copy.deepcopy(override)

    if isinstance(override, dict):
        hinted: dict[str, Any] = {}
        baseline_dict = baseline if isinstance(baseline, dict) else {}
        list_directives: dict[str, dict[str, str]] = {}

        for key, value in override.items():
            baseline_child = baseline_dict.get(key)
            hinted[key] = apply_merge_directive_hints(
                value,
                baseline_child,
                profile,
                list_strategy_default,
            )

            if profile in {"balanced", "aggressive"} and isinstance(value, list):
                if list_strategy_default == "append":
                    list_directives[key] = {"_merge_directive": "append"}
                elif list_strategy_default == "union":
                    list_directives[key] = {"_merge_directive": "union"}
                elif list_strategy_default == "merge_by_key_auto" and isinstance(baseline_child, list):
                    if value and baseline_child and all(
                        isinstance(item, dict) for item in (value + baseline_child)
                    ):
                        key_name = _infer_identity_key_for_dict_lists([
                            [item for item in value if isinstance(item, dict)],
                            [item for item in baseline_child if isinstance(item, dict)],
                        ])
                        if key_name:
                            list_directives[key] = {
                                "_merge_directive": "merge_by_key",
                                "_merge_key": key_name,
                            }
                    elif profile == "aggressive":
                        list_directives[key] = {"_merge_directive": "union"}

        if list_directives:
            hinted["_merge_list_directives"] = list_directives

        if isinstance(baseline, dict) and hinted:
            hinted.setdefault("_merge_directive", "merge_recursive")

        return hinted

    if isinstance(override, list):
        return [
            apply_merge_directive_hints(item, None, profile, list_strategy_default)
            for item in override
        ]

    return copy.deepcopy(override)


def parse_xml_to_payload(
    xml_file: str,
    resources: dict[str, Any],
) -> tuple[str, dict[str, Any], Optional[str]]:
    """Convert one XML config into hostname, payload, and device_type."""
    with open(xml_file) as f:
        raw = f.read()

    root = ElementTree.fromstring(f"<root>{raw}</root>")
    hostname = os.path.splitext(os.path.basename(xml_file))[0]
    hostname_elem = root.find(".//system/host-name")
    if hostname_elem is not None and hostname_elem.text:
        hostname = hostname_elem.text
    config = root.find(".//configuration")
    if config is None:
        raise ValueError(f"No <configuration> found in {xml_file}")

    xml_dict = elem_to_dict(config, "", resources["root"])
    return hostname, xml_dict, detect_device_type(xml_dict)


def write_yaml_file(output_path: str, payload: dict[str, Any]) -> None:
    """Write YAML payload to disk preserving key order."""
    yaml_output = yaml.dump(payload, sort_keys=False)
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    with open(output_path, "w") as f:
        f.write(yaml_output)


def load_yaml_file(input_path: str) -> dict[str, Any]:
    """Load a YAML mapping file and return an empty dict when missing or empty."""
    if not os.path.exists(input_path):
        return {}
    with open(input_path, "r") as f:
        data = yaml.safe_load(f) or {}
    return data if isinstance(data, dict) else {}


def deep_merge_dicts(base: dict[str, Any], override: dict[str, Any]) -> dict[str, Any]:
    """Deep merge two dictionaries with override precedence."""
    merged = copy.deepcopy(base)
    for key, value in override.items():
        if (
            key in merged
            and isinstance(merged[key], dict)
            and isinstance(value, dict)
        ):
            merged[key] = deep_merge_dicts(merged[key], value)
        else:
            merged[key] = copy.deepcopy(value)
    return merged


def load_schema(trimmed_json_file: str) -> dict[str, Any]:
    """Load and validate trimmed schema content."""
    with open(trimmed_json_file, "r") as f:
        schema = json.load(f)

    has_configuration = any(
        child.get("name") == "configuration"
        for child in schema.get("root", {}).get("children", [])
    )
    if not has_configuration:
        raise ValueError("No configuration node found in JSON schema")
    return schema


def parse_host_entries(
    xml_files: list[str],
    schema: dict[str, Any],
) -> list[tuple[str, dict[str, Any], Optional[str]]]:
    """Parse XML input files into normalized host entry tuples."""
    return [parse_xml_to_payload(xml_file, schema) for xml_file in xml_files]


def derive_provider_key(trimmed_json_file: str) -> str:
    """Derive provider-key from the single role directory inside provider roles/."""
    provider_root = os.path.dirname(os.path.abspath(trimmed_json_file))
    roles_root = os.path.join(provider_root, "roles")
    if not os.path.isdir(roles_root):
        raise ValueError(
            f"Unable to derive provider-key: missing roles directory next to {trimmed_json_file}"
        )

    role_dirs = sorted(
        entry
        for entry in os.listdir(roles_root)
        if os.path.isdir(os.path.join(roles_root, entry))
    )
    if len(role_dirs) != 1:
        raise ValueError(
            "Unable to derive provider-key: expected exactly one role directory under "
            f"{roles_root}, found {len(role_dirs)}"
        )
    return role_dirs[0]


def split_meta_payload(payload: dict[str, Any]) -> tuple[dict[str, Any], dict[str, Any]]:
    """Split payload into meta and non-meta sections."""
    if not isinstance(payload, dict):
        return {}, {}
    meta = payload.get(META_KEY, {})
    non_meta = {key: copy.deepcopy(value) for key, value in payload.items() if key != META_KEY}
    return meta if isinstance(meta, dict) else {}, non_meta


def _normalize_int(value: Any) -> Optional[int]:
    try:
        return int(value)
    except (TypeError, ValueError):
        return None


def normalize_registry(raw_registry: Any) -> dict[str, Any]:
    """Normalize registry metadata loaded from YAML."""
    registry: dict[str, Any] = {"version": 1, "providers": {}}
    if not isinstance(raw_registry, dict):
        return registry

    version = _normalize_int(raw_registry.get("version"))
    if version is not None:
        registry["version"] = version

    raw_providers = raw_registry.get(PROVIDERS_KEY, {})
    if not isinstance(raw_providers, dict):
        return registry

    normalized_providers: dict[str, Any] = {}
    for provider_key, raw_entry in raw_providers.items():
        if not isinstance(raw_entry, dict):
            continue
        entry: dict[str, Any] = {}
        managed_hosts = raw_entry.get("managed_hosts", [])
        if isinstance(managed_hosts, list):
            entry["managed_hosts"] = [str(host) for host in managed_hosts]

        raw_range = raw_entry.get("group_range")
        if isinstance(raw_range, dict):
            start = _normalize_int(raw_range.get("start"))
            end = _normalize_int(raw_range.get("end"))
            if start is not None and end is not None:
                entry["group_range"] = {"start": start, "end": end}

        group_names = raw_entry.get("group_names", [])
        if isinstance(group_names, list):
            entry["group_names"] = [str(name) for name in group_names]

        group_paths = raw_entry.get("group_paths", {})
        if isinstance(group_paths, dict):
            entry["group_paths"] = {
                str(name): str(path)
                for name, path in group_paths.items()
                if isinstance(path, str)
            }

        root_group = raw_entry.get("root_group")
        if isinstance(root_group, str):
            entry["root_group"] = root_group

        shared_payload = raw_entry.get("shared_payload", {})
        if isinstance(shared_payload, dict):
            entry["shared_payload"] = copy.deepcopy(shared_payload)

        normalized_providers[str(provider_key)] = entry

    registry[PROVIDERS_KEY] = normalized_providers
    return registry


def load_shared_all_state(group_vars_root: str) -> tuple[dict[str, Any], dict[str, Any]]:
    """Load shared all.yaml and split into payload and registry metadata."""
    all_file = os.path.join(group_vars_root, ALL_YAML)
    if not os.path.exists(all_file):
        all_file = os.path.join(group_vars_root, ALL_YML)
    payload = load_yaml_file(all_file)
    meta, non_meta = split_meta_payload(payload)
    registry = normalize_registry(meta.get(REGISTRY_KEY, {}))
    return non_meta, registry


def write_group_all_payload(directory: str, payload: dict[str, Any]) -> None:
    """Write compatibility copies for group all payload files."""
    write_yaml_file(os.path.join(directory, ALL_YAML), payload)
    write_yaml_file(os.path.join(directory, ALL_YML), payload)


def write_shared_all_state(
    group_vars_root: str,
    shared_payload: dict[str, Any],
    registry: dict[str, Any],
) -> None:
    """Persist shared all.yaml payload and registry metadata."""
    payload = copy.deepcopy(shared_payload)
    payload[META_KEY] = {REGISTRY_KEY: registry}
    write_group_all_payload(group_vars_root, payload)


def build_global_shared_payload_from_registry(registry: dict[str, Any]) -> dict[str, Any]:
    """Build all-provider shared payload from registry-stored provider payloads."""
    provider_payloads: list[dict[str, Any]] = []
    for provider_key in sorted(registry.get(PROVIDERS_KEY, {}).keys()):
        payload = registry[PROVIDERS_KEY][provider_key].get("shared_payload", {})
        if isinstance(payload, dict) and payload:
            provider_payloads.append(remove_merge_meta_keys(payload))

    if not provider_payloads:
        return {}

    shared = copy.deepcopy(provider_payloads[0])
    for payload in provider_payloads[1:]:
        merged = intersect_values(shared, payload)
        shared = merged if isinstance(merged, dict) else {}
    return shared if isinstance(shared, dict) else {}


def derive_host_delta_entries(
    full_payload_by_host: dict[str, dict[str, Any]],
    global_shared_payload: dict[str, Any],
) -> list[tuple[str, dict[str, Any]]]:
    """Build host payload deltas relative to shared all.yaml payload."""
    entries: list[tuple[str, dict[str, Any]]] = []
    for hostname in sorted(full_payload_by_host.keys()):
        delta = subtract_common(full_payload_by_host[hostname], global_shared_payload)
        if delta is _OMIT or not isinstance(delta, dict):
            delta = {}
        entries.append((hostname, delta))
    return entries


def _build_children_by_parent(parent_map: dict[str, Optional[str]]) -> dict[Optional[str], list[str]]:
    children: dict[Optional[str], list[str]] = {}
    for group_name, parent in parent_map.items():
        children.setdefault(parent, []).append(group_name)
    return children


def derive_common_host_groups(
    host_var_entries: list[tuple[str, dict[str, Any]]],
    min_hosts: int = 2,
    max_groups: int = 16,
    min_benefit_score: int = 1,
    min_new_paths: int = 0,
) -> dict[str, list[str]]:
    """Derive deterministic common host groups from shared leaf path/value support.

    Returns internal group tokens as keys (for example ``group:candidate1``) mapped
    to sorted host lists.
    """
    if not host_var_entries:
        return {}

    hostnames = [hostname for hostname, _payload in host_var_entries]
    all_hosts = sorted(set(hostnames))
    if not all_hosts:
        return {}

    token_support: dict[str, set[str]] = {}
    for hostname, payload in host_var_entries:
        leaf_map = _collect_leaf_path_values(payload)
        for path, value in leaf_map.items():
            token = f"{'.'.join(path)}={_value_key(value)}"
            token_support.setdefault(token, set()).add(hostname)

    set_to_tokens: dict[frozenset[str], set[str]] = {}
    for token, members in token_support.items():
        if len(members) < min_hosts:
            continue
        key = frozenset(members)
        set_to_tokens.setdefault(key, set()).add(token)

    # Always include a root group when possible.
    if len(all_hosts) >= min_hosts:
        all_key = frozenset(all_hosts)
        set_to_tokens.setdefault(all_key, set()).add("__all__")

    ranked: list[tuple[frozenset[str], int, int]] = []
    for members_set, tokens in set_to_tokens.items():
        if len(members_set) < min_hosts:
            continue
        benefit_score = len(tokens)
        if benefit_score < min_benefit_score:
            continue
        new_paths_score = max(0, benefit_score - 1)
        if new_paths_score < min_new_paths:
            continue
        ranked.append((members_set, len(members_set), benefit_score))

    ranked.sort(key=lambda item: (-item[1], -item[2], sorted(item[0])))

    groups: dict[str, list[str]] = {}
    for members_set, _size, _benefit in ranked[:max_groups]:
        group_name = f"group:candidate{len(groups) + 1}"
        groups[group_name] = sorted(members_set)

    return groups


def _infer_parent_map_from_groups(common_groups: dict[str, list[str]]) -> dict[str, Optional[str]]:
    """Infer parent links from strict host-set containment."""
    parent_map: dict[str, Optional[str]] = {name: None for name in common_groups.keys()}
    for group_name, members in common_groups.items():
        group_set = set(members)
        candidates: list[str] = []
        for other_name, other_members in common_groups.items():
            if other_name == group_name:
                continue
            other_set = set(other_members)
            if group_set < other_set:
                candidates.append(other_name)
        if candidates:
            candidates.sort(key=lambda name: (len(common_groups[name]), name))
            parent_map[group_name] = candidates[0]
    return parent_map


def collapse_daisy_chains(
    common_groups: dict[str, list[str]],
    parent_map: dict[str, Optional[str]],
    payload_by_hostname: dict[str, dict[str, Any]],
    max_single_child_chain: int = 2,
    min_unique_paths: int = 1,
) -> tuple[dict[str, list[str]], dict[str, Optional[str]]]:
    """Collapse low-value single-child chain nodes based on unique payload paths."""
    if max_single_child_chain < 2:
        return dict(common_groups), dict(parent_map)

    reduced_groups = dict(common_groups)
    reduced_parent_map = dict(parent_map)

    changed = True
    while changed:
        changed = False
        children_by_parent = _build_children_by_parent(reduced_parent_map)

        for group_name in sorted(list(reduced_parent_map.keys())):
            parent = reduced_parent_map.get(group_name)
            children = children_by_parent.get(group_name, [])
            if parent is None or len(children) != 1:
                continue

            members = reduced_groups.get(group_name, [])
            parent_members = reduced_groups.get(parent, [])
            if not members or not parent_members:
                continue

            group_payload = build_group_shared_payload([
                payload_by_hostname[host]
                for host in members
                if host in payload_by_hostname
            ])
            parent_payload = build_group_shared_payload([
                payload_by_hostname[host]
                for host in parent_members
                if host in payload_by_hostname
            ])

            unique = subtract_common(group_payload, parent_payload)
            if unique is _OMIT:
                unique_paths_count = 0
            else:
                compacted = compact_payload(unique)
                unique_paths_count = len(_collect_paths(compacted if compacted is not _OMIT else {}))

            if unique_paths_count >= min_unique_paths:
                continue

            child = children[0]
            reduced_parent_map[child] = parent
            reduced_parent_map.pop(group_name, None)
            reduced_groups.pop(group_name, None)
            changed = True
            break

    return reduced_groups, reduced_parent_map


def build_group_full_payloads(
    common_groups: dict[str, list[str]],
    payload_by_hostname: dict[str, dict[str, Any]],
) -> dict[str, dict[str, Any]]:
    """Build full payloads for groups from member host intersections."""
    full_payloads: dict[str, dict[str, Any]] = {}
    for group_name, members in common_groups.items():
        payloads = [payload_by_hostname[member] for member in members if member in payload_by_hostname]
        full_payloads[group_name] = build_group_shared_payload(payloads)
    return full_payloads


def build_group_path_map(parent_map: dict[str, Optional[str]]) -> dict[str, str]:
    """Map group names to flat directory paths under group_vars/."""
    return {group_name: _plain_group_name(group_name) for group_name in parent_map.keys()}


def ancestor_chain(group_name: str, parent_map: dict[str, Optional[str]]) -> list[str]:
    """Return ancestor chain from root group to the provided group."""
    chain: list[str] = []
    current: Optional[str] = group_name
    while current is not None:
        chain.append(current)
        current = parent_map.get(current)
    chain.reverse()
    return chain


def assign_leaf_group_per_host(
    common_groups: dict[str, list[str]],
    parent_map: dict[str, Optional[str]],
) -> dict[str, str]:
    """Assign each host to one deterministic deepest group."""
    children_by_parent = _build_children_by_parent(parent_map)
    leaves = [name for name in common_groups.keys() if not children_by_parent.get(name)]
    leaf_members = {name: set(common_groups[name]) for name in leaves}

    host_to_leaf: dict[str, str] = {}
    all_hosts = sorted({host for hosts in common_groups.values() for host in hosts})
    for host in all_hosts:
        candidates = [name for name, members in leaf_members.items() if host in members]
        if not candidates:
            candidates = [name for name, members in common_groups.items() if host in members]
        if not candidates:
            continue
        candidates.sort(key=lambda name: (len(common_groups[name]), name))
        host_to_leaf[host] = candidates[0]
    return host_to_leaf


def _set_path(payload: dict[str, Any], path: tuple[str, ...], value: Any) -> None:
    cursor = payload
    for segment in path[:-1]:
        if segment not in cursor or not isinstance(cursor[segment], dict):
            cursor[segment] = {}
        cursor = cursor[segment]
    cursor[path[-1]] = copy.deepcopy(value)


def _delete_path(payload: dict[str, Any], path: tuple[str, ...]) -> None:
    if not path:
        return

    cursor: Any = payload
    stack: list[tuple[dict[str, Any], str]] = []
    for segment in path:
        if not isinstance(cursor, dict) or segment not in cursor:
            return
        stack.append((cursor, segment))
        cursor = cursor[segment]

    parent, leaf = stack[-1]
    del parent[leaf]
    for node, key in reversed(stack[:-1]):
        child = node.get(key)
        if isinstance(child, dict) and not child:
            del node[key]
        else:
            break


def detect_and_fallback_sibling_conflicts(
    common_groups: dict[str, list[str]],
    parent_map: dict[str, Optional[str]],
    group_full_payloads: dict[str, dict[str, Any]],
    payload_by_hostname: dict[str, dict[str, Any]],
) -> dict[str, dict[str, Any]]:
    """Move unresolved sibling conflicts into host-specific fallback payloads."""
    host_fallbacks: dict[str, dict[str, Any]] = {}
    children_by_parent = _build_children_by_parent(parent_map)

    for _parent, siblings in children_by_parent.items():
        if len(siblings) < 2:
            continue
        ordered_siblings = sorted(siblings)
        for index, left in enumerate(ordered_siblings):
            for right in ordered_siblings[index + 1:]:
                overlap_hosts = set(common_groups[left]) & set(common_groups[right])
                if not overlap_hosts:
                    continue

                left_paths = _collect_leaf_path_values(group_full_payloads.get(left, {}))
                right_paths = _collect_leaf_path_values(group_full_payloads.get(right, {}))
                shared_paths = set(left_paths.keys()) & set(right_paths.keys())

                for path in sorted(shared_paths):
                    if _value_key(left_paths[path]) == _value_key(right_paths[path]):
                        continue
                    for host in sorted(overlap_hosts):
                        host_values = _collect_leaf_path_values(payload_by_hostname.get(host, {}))
                        if path not in host_values:
                            continue
                        host_fallbacks.setdefault(host, {})
                        _set_path(host_fallbacks[host], path, host_values[path])
                    _delete_path(group_full_payloads[left], path)
                    _delete_path(group_full_payloads[right], path)

    return host_fallbacks


def build_group_delta_payloads(
    parent_map: dict[str, Optional[str]],
    group_full_payloads: dict[str, dict[str, Any]],
    merge_profile: str,
    list_strategy_default: str,
) -> dict[str, dict[str, Any]]:
    """Compute strict deltas for groups against parent ancestry payloads."""
    group_deltas: dict[str, dict[str, Any]] = {}
    ordered_names = sorted(
        parent_map.keys(),
        key=lambda name: (len(ancestor_chain(name, parent_map)), name),
    )
    for group_name in ordered_names:
        parent = parent_map[group_name]
        baseline = group_full_payloads.get(parent, {}) if parent is not None else {}
        delta = subtract_common(group_full_payloads.get(group_name, {}), baseline)
        if delta is _OMIT:
            payload: dict[str, Any] = {}
        else:
            compacted = compact_payload(delta)
            payload = compacted if isinstance(compacted, dict) else {}
        group_deltas[group_name] = apply_merge_directive_hints(
            payload,
            baseline,
            merge_profile,
            list_strategy_default,
        ) if merge_profile != "off" else payload
    return group_deltas


def write_group_hierarchy_payloads(
    group_vars_root: str,
    parent_map: dict[str, Optional[str]],
    group_delta_payloads: dict[str, dict[str, Any]],
    path_prefix: str = "",
) -> dict[str, str]:
    """Write group hierarchy directories with all.yaml payload files."""
    path_map = build_group_path_map(parent_map)
    if path_prefix:
        path_map = {
            name: os.path.join(path_prefix, relative_path)
            for name, relative_path in path_map.items()
        }
    for group_name in sorted(path_map.keys(), key=lambda name: path_map[name]):
        output_dir = os.path.join(group_vars_root, path_map[group_name])
        write_group_all_payload(output_dir, group_delta_payloads.get(group_name, {}))
    return path_map


def rewrite_host_vars_with_hierarchy(
    host_entries: list[tuple[str, dict[str, Any], Optional[str]]],
    host_vars_root: str,
    global_payload: dict[str, Any],
    parent_map: dict[str, Optional[str]],
    group_full_payloads: dict[str, dict[str, Any]],
    host_to_leaf_group: dict[str, str],
    host_fallback_overrides: dict[str, dict[str, Any]],
    merge_profile: str,
    list_strategy_default: str,
) -> None:
    """Rewrite host_vars as strict deltas against global plus hierarchy baseline."""
    for hostname, full_payload, _detected_type in host_entries:
        baseline = copy.deepcopy(global_payload)
        leaf_group = host_to_leaf_group.get(hostname)
        if leaf_group:
            for group_name in ancestor_chain(leaf_group, parent_map):
                baseline = deep_merge_dicts(baseline, group_full_payloads.get(group_name, {}))

        fallback_payload = host_fallback_overrides.get(hostname, {})
        if fallback_payload:
            baseline = deep_merge_dicts(baseline, fallback_payload)

        delta = subtract_common(full_payload, baseline)
        if delta is _OMIT:
            payload: dict[str, Any] = {}
        else:
            compacted = compact_payload(delta)
            payload = compacted if isinstance(compacted, dict) else {}

        hinted = apply_merge_directive_hints(
            payload,
            baseline,
            merge_profile,
            list_strategy_default,
        ) if merge_profile != "off" else payload
        write_yaml_file(os.path.join(host_vars_root, f"{hostname}.yaml"), hinted)


def inventory_group_sort_key(name: str) -> tuple[int, int, str]:
    """Sort inventory groups lexicographically by name."""
    return (0, 0, name)


def load_inventory_sections(inventory_path: str) -> dict[str, Any]:
    """Load inventory into all, host-group, and children-group sections."""
    result = {"all": [], "hosts": {}, "children": {}}
    if not os.path.exists(inventory_path):
        return result

    current_name: Optional[str] = None
    current_kind: Optional[str] = None
    with open(inventory_path, "r") as f:
        for line in f:
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue
            if stripped.startswith("[") and stripped.endswith("]"):
                section = stripped[1:-1]
                if section == "all":
                    current_name = "all"
                    current_kind = "all"
                elif section.endswith(":children"):
                    current_name = section[:-9]
                    current_kind = "children"
                    result["children"].setdefault(current_name, [])
                else:
                    current_name = section
                    current_kind = "hosts"
                    result["hosts"].setdefault(current_name, [])
                continue

            if current_kind == "all":
                result["all"].append(stripped.split()[0])
            elif current_kind == "hosts" and current_name:
                result["hosts"][current_name].append(stripped.split()[0])
            elif current_kind == "children" and current_name:
                result["children"][current_name].append(stripped)

    return result


def _parse_grouping_hosts_file(grouping_hosts_file: str) -> tuple[dict[str, Any], list[str]]:
    """Parse grouping.hosts file and return parse errors with line context."""
    result = {"all": [], "hosts": {}, "children": {}}
    errors: list[str] = []

    if not os.path.exists(grouping_hosts_file):
        return result, [f"{grouping_hosts_file}: file does not exist"]
    if not os.path.isfile(grouping_hosts_file):
        return result, [f"{grouping_hosts_file}: not a regular file"]

    current_name: Optional[str] = None
    current_kind: Optional[str] = None
    seen_sections: set[str] = set()

    with open(grouping_hosts_file, "r") as f:
        for line_no, line in enumerate(f, start=1):
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue

            if stripped.startswith("[") or stripped.endswith("]"):
                if not (stripped.startswith("[") and stripped.endswith("]")):
                    errors.append(f"line {line_no}: malformed section header: {stripped}")
                    current_name = None
                    current_kind = None
                    continue

                section = stripped[1:-1].strip()
                if not section:
                    errors.append(f"line {line_no}: empty section header")
                    current_name = None
                    current_kind = None
                    continue

                if section in seen_sections:
                    errors.append(f"line {line_no}: duplicate section [{section}]")
                seen_sections.add(section)

                if section == "all":
                    current_name = "all"
                    current_kind = "all"
                elif section.endswith(":children"):
                    group_name = section[:-9].strip()
                    if not group_name:
                        errors.append(f"line {line_no}: invalid children section name [{section}]")
                        current_name = None
                        current_kind = None
                        continue
                    current_name = group_name
                    current_kind = "children"
                    result["children"].setdefault(current_name, [])
                else:
                    current_name = section
                    current_kind = "hosts"
                    result["hosts"].setdefault(current_name, [])
                continue

            if current_kind is None:
                errors.append(f"line {line_no}: entry outside section: {stripped}")
                continue

            token = stripped.split()[0]
            if current_kind == "all":
                result["all"].append(token)
            elif current_kind == "hosts" and current_name:
                result["hosts"][current_name].append(token)
            elif current_kind == "children" and current_name:
                result["children"][current_name].append(token)

    return result, errors


def _detect_group_cycle(children_map: dict[str, list[str]]) -> Optional[list[str]]:
    """Return one cycle path if hierarchy contains a cycle."""
    visited: set[str] = set()
    in_stack: set[str] = set()
    path: list[str] = []

    def dfs(node: str) -> Optional[list[str]]:
        visited.add(node)
        in_stack.add(node)
        path.append(node)

        for child in children_map.get(node, []):
            if child not in visited:
                cycle = dfs(child)
                if cycle:
                    return cycle
            elif child in in_stack:
                cycle_start = path.index(child)
                return path[cycle_start:] + [child]

        path.pop()
        in_stack.remove(node)
        return None

    all_groups = set(children_map.keys())
    for children in children_map.values():
        all_groups.update(children)

    for node in sorted(all_groups):
        if node in visited:
            continue
        cycle = dfs(node)
        if cycle:
            return cycle
    return None


def _build_user_groups_from_inventory(
    parsed_inventory: dict[str, Any],
    active_hostnames: list[str],
    strict_known_hosts: bool,
) -> tuple[dict[str, list[str]], dict[str, Optional[str]], dict[str, str], list[str]]:
    """Build user-defined group memberships, parent map, and host leaf assignment."""
    errors: list[str] = []
    active_set = set(active_hostnames)

    hosts_map: dict[str, list[str]] = {
        name: list(dict.fromkeys(hosts))
        for name, hosts in parsed_inventory.get("hosts", {}).items()
        if name != "all"
    }
    children_map: dict[str, list[str]] = {
        name: list(dict.fromkeys(children))
        for name, children in parsed_inventory.get("children", {}).items()
    }

    defined_groups = set(hosts_map.keys()) | set(children_map.keys())
    for _parent, children in children_map.items():
        for child in children:
            if child not in defined_groups:
                errors.append(f"undefined child group reference: '{child}'")

    cycle = _detect_group_cycle(children_map)
    if cycle:
        errors.append("group hierarchy cycle detected: " + " -> ".join(cycle))

    parent_of: dict[str, str] = {}
    for parent, children in children_map.items():
        for child in children:
            existing = parent_of.get(child)
            if existing is not None and existing != parent:
                errors.append(f"group '{child}' has multiple parents: '{existing}' and '{parent}'")
            else:
                parent_of[child] = parent

    if strict_known_hosts:
        for group_name, hosts in hosts_map.items():
            unknown = sorted(set(hosts) - active_set)
            for host in unknown:
                errors.append(f"group '{group_name}' references unknown host '{host}'")

    common_groups: dict[str, list[str]] = {}

    def resolve_members(group_name: str, stack: Optional[set[str]] = None) -> set[str]:
        if group_name in common_groups:
            return set(common_groups[group_name])

        local_stack = set() if stack is None else set(stack)
        if group_name in local_stack:
            return set()
        local_stack.add(group_name)

        members = set(hosts_map.get(group_name, []))
        for child in children_map.get(group_name, []):
            members |= resolve_members(child, local_stack)

        members &= active_set
        common_groups[group_name] = sorted(members)
        return members

    for group_name in sorted(defined_groups):
        resolve_members(group_name)

    common_groups = {
        group_name: members
        for group_name, members in common_groups.items()
        if members
    }

    parent_map: dict[str, Optional[str]] = {}
    for group_name in common_groups.keys():
        parent = parent_of.get(group_name)
        while parent is not None and parent not in common_groups:
            parent = parent_of.get(parent)
        parent_map[group_name] = parent

    children_by_parent = _build_children_by_parent(parent_map)
    leaves = [name for name in common_groups.keys() if not children_by_parent.get(name)]
    host_to_leaf: dict[str, str] = {}
    for host in active_hostnames:
        candidates = [name for name in leaves if host in set(common_groups.get(name, []))]
        if not candidates:
            candidates = [name for name, members in common_groups.items() if host in set(members)]
        if not candidates:
            errors.append(f"host '{host}' is not part of any defined group")
            continue
        candidates.sort(key=lambda name: (len(ancestor_chain(name, parent_map)), name), reverse=True)
        host_to_leaf[host] = candidates[0]

    return common_groups, parent_map, host_to_leaf, errors


def _auto_grouping_from_host_payloads(
    host_var_entries: list[tuple[str, dict[str, Any]]],
) -> tuple[dict[str, Any], dict[str, list[str]], dict[str, Optional[str]], dict[str, str]]:
    """Build deterministic grouping inventory and hierarchy when no grouping.hosts is provided."""
    active_hostnames = sorted(hostname for hostname, _payload in host_var_entries)
    common_groups = derive_common_host_groups(
        host_var_entries,
        min_hosts=2,
        max_groups=max(4, len(active_hostnames) * 2),
        min_benefit_score=1,
        min_new_paths=0,
    )

    has_root = any(set(members) == set(active_hostnames) for members in common_groups.values())
    if len(active_hostnames) >= 2 and not has_root:
        common_groups[f"group:candidate{len(common_groups) + 1}"] = active_hostnames

    parent_map = _infer_parent_map_from_groups(common_groups)
    host_to_leaf = assign_leaf_group_per_host(common_groups, parent_map)
    inventory = build_hierarchical_inventory_groups(parent_map, host_to_leaf)
    return inventory, common_groups, parent_map, host_to_leaf


def build_hierarchical_inventory_groups(
    parent_map: dict[str, Optional[str]],
    host_to_leaf_group: dict[str, str],
) -> dict[str, Any]:
    """Build inventory sections for host memberships and parent-child links."""
    children_by_parent: dict[str, list[str]] = {}
    for group_name, parent in parent_map.items():
        if parent is None:
            continue
        parent_name = _plain_group_name(parent)
        child_name = _plain_group_name(group_name)
        children_by_parent.setdefault(parent_name, []).append(child_name)

    hosts_by_group: dict[str, list[str]] = {}
    for host, group_name in host_to_leaf_group.items():
        for ancestor in ancestor_chain(group_name, parent_map):
            key = _plain_group_name(ancestor)
            hosts_by_group.setdefault(key, []).append(host)

    for key in list(children_by_parent.keys()):
        children_by_parent[key] = sorted(set(children_by_parent[key]))
    for key in list(hosts_by_group.keys()):
        hosts_by_group[key] = sorted(set(hosts_by_group[key]))

    return {"hosts": hosts_by_group, "children": children_by_parent}


def write_inventory(
    hosts_file: str,
    active_hostnames: list[str],
    inventory_groups: dict[str, Any],
    owned_group_names: list[str],
) -> None:
    """Write or update inventory while preserving unrelated provider sections."""
    existing = load_inventory_sections(hosts_file)
    owned = set(owned_group_names)

    merged_all_hosts = sorted(set(existing.get("all", [])) | set(active_hostnames))
    merged_host_groups = {
        name: hosts
        for name, hosts in existing.get("hosts", {}).items()
        if name not in owned
    }
    merged_children_groups = {
        name: children
        for name, children in existing.get("children", {}).items()
        if name not in owned
    }

    for group_name, hosts in inventory_groups.get("hosts", {}).items():
        merged_host_groups[group_name] = sorted(set(hosts))
    for group_name, children in inventory_groups.get("children", {}).items():
        merged_children_groups[group_name] = sorted(set(children))

    with open(hosts_file, "w") as f:
        f.write("[all]\n")
        for hostname in merged_all_hosts:
            f.write(f"{hostname}\n")

        for group_name in sorted(merged_host_groups.keys(), key=inventory_group_sort_key):
            f.write(f"\n[{group_name}]\n")
            for hostname in merged_host_groups[group_name]:
                f.write(f"{hostname}\n")

        for group_name in sorted(merged_children_groups.keys(), key=inventory_group_sort_key):
            f.write(f"\n[{group_name}:children]\n")
            for child_name in merged_children_groups[group_name]:
                f.write(f"{child_name}\n")


def _root_group_paths(group_paths: dict[str, str]) -> list[str]:
    """Return only root paths for a provider-owned group hierarchy."""
    sorted_paths = sorted(set(group_paths.values()), key=lambda path: (path.count(os.sep), path))
    roots: list[str] = []
    for path in sorted_paths:
        if any(path == root or path.startswith(root + os.sep) for root in roots):
            continue
        roots.append(path)
    return roots


def clear_owned_group_dirs(group_vars_root: str, group_paths: dict[str, str]) -> None:
    """Remove previously owned group hierarchy directories for the active provider."""
    for relative_root in _root_group_paths(group_paths):
        absolute_root = os.path.join(group_vars_root, relative_root)
        if os.path.isdir(absolute_root):
            shutil.rmtree(absolute_root)


def refresh_foreign_provider_root_payloads(
    group_vars_root: str,
    registry: dict[str, Any],
    active_provider_key: str,
    global_shared_payload: dict[str, Any],
    merge_profile: str,
    list_strategy_default: str,
) -> None:
    """Refresh foreign provider root group payloads when shared all.yaml changes."""
    providers = registry.get(PROVIDERS_KEY, {})
    for provider_key, entry in providers.items():
        if provider_key == active_provider_key:
            continue
        root_group = entry.get("root_group")
        group_paths = entry.get("group_paths", {})
        shared_payload = entry.get("shared_payload", {})
        if not isinstance(shared_payload, dict) or not root_group or root_group not in group_paths:
            continue

        delta = subtract_common(shared_payload, global_shared_payload)
        if delta is _OMIT:
            payload: dict[str, Any] = {}
        else:
            compacted = compact_payload(delta)
            payload = compacted if isinstance(compacted, dict) else {}

        hinted = apply_merge_directive_hints(
            payload,
            global_shared_payload,
            merge_profile,
            list_strategy_default,
        ) if merge_profile != "off" else payload
        write_group_all_payload(
            os.path.join(group_vars_root, group_paths[root_group]),
            hinted,
        )


def assign_provider_group_ranges(registry: dict[str, Any]) -> None:
    """Assign deterministic non-overlapping group index ranges per provider."""
    providers = registry.get(PROVIDERS_KEY, {})
    if not isinstance(providers, dict):
        return

    cursor = 0
    for provider_key, entry in providers.items():
        if not isinstance(entry, dict):
            continue
        group_names = entry.get("group_names", [])
        group_count = len(group_names) if isinstance(group_names, list) else 0
        width = max(1, group_count)
        start = cursor
        end = cursor + width - 1
        entry["group_range"] = {"start": start, "end": end}
        cursor = end + 1


def main() -> None:
    """Generate generic hierarchical group_vars/host_vars and inventory from XML."""
    parser = argparse.ArgumentParser(
        description="Generate Ansible hosts and hierarchical group_vars/host_vars from XML using trimmed schema.",
        exit_on_error=True,
    )
    parser.add_argument(
        "-j",
        "--trimmed_json",
        required=True,
        help="Path to trimmed_schema.json generated by jtaf-provider/jtaf-yang2go.",
    )
    parser.add_argument(
        "-x",
        "--xml-config",
        required=True,
        nargs="+",
        help="One or more Junos XML config files to convert into host_vars YAML.",
    )
    parser.add_argument(
        "-d",
        "--directory",
        required=True,
        help="Output directory for hosts file and host_vars/*.yaml.",
    )
    parser.add_argument(
        "--hosts-file",
        default=None,
        help="Optional path to inventory hosts file. Defaults to <directory>/hosts.",
    )
    parser.add_argument(
        "--host-vars-dir",
        default=None,
        help="Optional host_vars directory. Defaults to <directory>/host_vars.",
    )
    parser.add_argument(
        "--group-vars-dir",
        default=None,
        help="Optional group_vars directory. Defaults to <directory>/group_vars.",
    )
    parser.add_argument(
        "--grouping-hosts-file",
        default=None,
        help="Optional path to user-defined grouping.hosts file. If omitted, groups are auto-derived.",
    )
    parser.add_argument(
        "--strict-grouping-known-hosts",
        action="store_true",
        default=False,
        help="Fail when grouping.hosts references hosts not present in current XML input set.",
    )
    parser.add_argument(
        "--merge-directive-profile",
        choices=["off", "minimal", "balanced", "aggressive"],
        default="balanced",
    )
    parser.add_argument(
        "--merge-list-strategy-default",
        choices=["replace", "union", "append", "merge_by_key_auto"],
        default="merge_by_key_auto",
    )
    args = parser.parse_args()

    schema = load_schema(args.trimmed_json)
    provider_key = derive_provider_key(args.trimmed_json)

    directory = args.directory
    hosts_file = args.hosts_file or os.path.join(directory, "hosts")
    host_vars_dir = args.host_vars_dir or os.path.join(directory, "host_vars")
    group_vars_dir = args.group_vars_dir or os.path.join(directory, "group_vars")

    os.makedirs(os.path.dirname(hosts_file) or ".", exist_ok=True)
    os.makedirs(host_vars_dir, exist_ok=True)
    os.makedirs(group_vars_dir, exist_ok=True)

    host_entries = parse_host_entries(args.xml_config, schema)
    full_payload_by_host = {
        hostname: remove_merge_meta_keys(payload)
        for hostname, payload, _device_type in host_entries
    }
    active_hostnames = sorted(full_payload_by_host.keys())

    if args.grouping_hosts_file:
        parsed_inventory, parse_errors = _parse_grouping_hosts_file(args.grouping_hosts_file)
        if parse_errors:
            raise SystemExit("grouping.hosts parsing failed:\n- " + "\n- ".join(parse_errors))
    else:
        parsed_inventory = {"all": active_hostnames, "hosts": {}, "children": {}}

    _existing_all_payload, registry = load_shared_all_state(group_vars_dir)
    providers = registry.setdefault(PROVIDERS_KEY, {})
    old_entry = copy.deepcopy(providers.get(provider_key, {}))
    provider_entry = copy.deepcopy(old_entry)
    provider_entry["managed_hosts"] = active_hostnames
    provider_entry["shared_payload"] = build_shared_payload(
        [full_payload_by_host[hostname] for hostname in active_hostnames]
    )
    providers[provider_key] = provider_entry

    global_shared_payload = build_global_shared_payload_from_registry(registry)
    active_host_delta_entries = derive_host_delta_entries(full_payload_by_host, global_shared_payload)
    payload_by_hostname = {hostname: payload for hostname, payload in active_host_delta_entries}

    if args.grouping_hosts_file:
        common_groups, parent_map, host_to_leaf_group, grouping_errors = _build_user_groups_from_inventory(
            parsed_inventory,
            active_hostnames,
            strict_known_hosts=args.strict_grouping_known_hosts,
        )
        if grouping_errors:
            raise SystemExit("grouping.hosts validation failed:\n- " + "\n- ".join(grouping_errors))
    else:
        auto_inventory, common_groups, parent_map, host_to_leaf_group = _auto_grouping_from_host_payloads(
            active_host_delta_entries
        )
        parsed_inventory = {
            "all": active_hostnames,
            "hosts": auto_inventory.get("hosts", {}),
            "children": auto_inventory.get("children", {}),
        }

    group_full_payloads = build_group_full_payloads(common_groups, payload_by_hostname)
    host_fallback_overrides = detect_and_fallback_sibling_conflicts(
        common_groups,
        parent_map,
        group_full_payloads,
        payload_by_hostname,
    )

    group_delta_payloads = build_group_delta_payloads(
        parent_map,
        group_full_payloads,
        args.merge_directive_profile,
        args.merge_list_strategy_default,
    )

    old_group_paths = old_entry.get("group_paths", {}) if isinstance(old_entry, dict) else {}
    old_group_names = old_entry.get("group_names", []) if isinstance(old_entry, dict) else []
    clear_owned_group_dirs(group_vars_dir, old_group_paths)
    provider_path_prefix = sanitize_group_name(provider_key) if len(providers) > 1 else ""
    group_paths = write_group_hierarchy_payloads(
        group_vars_dir,
        parent_map,
        group_delta_payloads,
        path_prefix=provider_path_prefix,
    )

    roots = sorted(
        [name for name, parent in parent_map.items() if parent is None],
        key=lambda name: inventory_group_sort_key(_plain_group_name(name)),
    )
    provider_entry["group_names"] = [_plain_group_name(name) for name in common_groups.keys()]
    provider_entry["group_paths"] = {
        _plain_group_name(name): path for name, path in group_paths.items()
    }
    provider_entry["root_group"] = _plain_group_name(roots[0]) if roots else None
    providers[provider_key] = provider_entry
    assign_provider_group_ranges(registry)

    write_shared_all_state(group_vars_dir, global_shared_payload, registry)
    refresh_foreign_provider_root_payloads(
        group_vars_dir,
        registry,
        provider_key,
        global_shared_payload,
        args.merge_directive_profile,
        args.merge_list_strategy_default,
    )

    rewrite_host_vars_with_hierarchy(
        host_entries,
        host_vars_dir,
        global_shared_payload,
        parent_map,
        group_full_payloads,
        host_to_leaf_group,
        host_fallback_overrides,
        args.merge_directive_profile,
        args.merge_list_strategy_default,
    )

    active_set = set(active_hostnames)
    inventory_groups = {
        "hosts": {
            group_name: sorted(set(host for host in hosts if host in active_set))
            for group_name, hosts in parsed_inventory.get("hosts", {}).items()
            if group_name != "all"
        },
        "children": (
            {
                group_name: sorted(set(children))
                for group_name, children in parsed_inventory.get("children", {}).items()
            }
            if args.grouping_hosts_file
            else {}
        ),
    }
    write_inventory(hosts_file, active_hostnames, inventory_groups, old_group_names)


if __name__ == "__main__":
    main()
