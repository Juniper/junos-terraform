#!/usr/bin/env python3
import argparse
import copy
import json
import os
import yaml
from xml.etree import ElementTree
from typing import Any


_OMIT = object()


def prepare_tag(tag:str) -> str:
    """Prepare XML tag to be used as YAML key by replacing '-' and '.' with '_'."""
    return tag.replace("-", "_").replace(".", "_")

# def element_node(element:ElementTree.Element,path:str,resources:dict[str,Any]) -> dict[str,Any]|None:
def element_node(element:ElementTree.Element,path:str,resources:dict[str,Any]):
    """Return the resource node matching the given XML element and path.
    Args:
        element: XML element to match
        path: path to match in the schema
        resources: schema resource node to search
    Returns:
        The matching resource node or None if not found
    """
    
    if resources['name'] == element.tag and (resources.get("path") is None or (resources["path"]+'/'+element.tag)==path):
        return {k: v for k, v in resources.items() if k != "children"}
    try:
        for elem in resources["children"]:
                etype=element_node(element,path,elem)
                if etype:
                    return etype                  
    except KeyError:
        return None            
    return None


def elem_to_dict(element:ElementTree.Element,path:str,resources:Any)-> dict[str, Any]:
    """Convert an XML element and its children to a dictionary.
    Args:
        element: XML element to convert
        path: current path of the element. Needed to uniquely identify the element in the schema
        resources: schema resource node to use for type information
    Returns:
        A dictionary representation of the XML element
    """
    
    result = {}
    for child in element:
        prepared_tag=prepare_tag(child.tag)
        prepared_path=child.tag            
        if len(path)>0:
            prepared_path=path+'/'+child.tag
        elem_node=element_node(child,prepared_path,resources)    
        elem_type=elem_node['type'] if elem_node else None

        if elem_type == 'list':
            # If the element is of type list, always create a list
            
            if not result.get(prepared_tag):
                result[prepared_tag] = []
            if len(child) > 0:
                result[prepared_tag].append(elem_to_dict(child,prepared_path,resources))
            else:
                result[prepared_tag].append(child.text)
        elif elem_type == 'leaf-list':
            # If the element is of type leaf-list, always create a list
            result[prepared_tag] = child.text        
        elif elem_type == 'container':
            # If the element is of type container, always create a dict
            if len(child) > 0:
                result[prepared_tag] = elem_to_dict(child,prepared_path,resources)
            else:
                result[prepared_tag] = ""
        else:
            # For other types, decide based on children
            if len(child) > 0:
                result[prepared_tag] = elem_to_dict(child,prepared_path,resources)
            else:
                if elem_type=='leaf':
                    if not child.text:
                        result[prepared_tag] = True
                    else:
                        result[prepared_tag] = child.text    
                else:
                    result[prepared_tag] = child.text     
    return result


def intersect_values(left: Any, right: Any):
    """Return shared structure/value between two objects.

    Dicts are intersected recursively by key. Lists/scalars are shared only
    when exactly equal.
    """
    if type(left) is not type(right):
        return _OMIT

    if isinstance(left, dict):
        common = {}
        for key in left.keys() & right.keys():
            shared_value = intersect_values(left[key], right[key])
            if shared_value is not _OMIT:
                common[key] = shared_value
        return common

    if isinstance(left, list):
        return copy.deepcopy(left) if left == right else _OMIT

    return copy.deepcopy(left) if left == right else _OMIT


def subtract_common(value: Any, common: Any):
    """Return value with shared structure removed recursively."""
    if common is _OMIT:
        return copy.deepcopy(value)

    if type(value) is not type(common):
        return copy.deepcopy(value)

    if isinstance(value, dict):
        delta = {}
        for key, item in value.items():
            if key in common:
                stripped = subtract_common(item, common[key])
                if stripped is not _OMIT:
                    delta[key] = stripped
            else:
                delta[key] = copy.deepcopy(item)
        return delta if delta else _OMIT

    if isinstance(value, list):
        return _OMIT if value == common else copy.deepcopy(value)

    return _OMIT if value == common else copy.deepcopy(value)


def build_shared_payload(host_payloads: list[dict[str, Any]]) -> dict[str, Any]:
    """Build one shared dictionary from all host payload dictionaries."""
    if not host_payloads:
        return {}
    shared = copy.deepcopy(host_payloads[0])
    for payload in host_payloads[1:]:
        shared = intersect_values(shared, payload)
        if shared is _OMIT:
            return {}
    if isinstance(shared, dict):
        return shared
    return {}


def parse_xml_to_payload(xml_file:str, resources:dict[str,Any]) -> tuple[str, dict[str, Any]]:
    """Convert one XML config into hostname and payload dictionary."""
    with open(xml_file) as f:
        raw = f.read()
    root = ElementTree.fromstring(f"<root>{raw}</root>")
    hostname = xml_file.split('.')[0]
    hostname_elem = root.find(".//system/host-name")
    if hostname_elem is not None and hostname_elem.text:
        hostname = hostname_elem.text  
    config = root.find(".//configuration")
    if config is None:
        raise ValueError(f"No <configuration> found in {xml_file}")
    xml_dict = elem_to_dict(config,"",resources['root'])
    return hostname, xml_dict


def write_yaml_file(output_path: str, payload: dict[str, Any]) -> None:
    """Write YAML payload to disk preserving key order."""
    yaml_output = yaml.dump(payload, sort_keys=False)
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    with open(output_path, "w") as f:
        f.write(yaml_output)


def write_host_override(output_dir: str, hostname: str, host_payload: dict[str, Any], shared_payload: dict[str, Any]) -> None:
    """Write host override YAML after removing shared values."""
    delta_payload = subtract_common(host_payload, shared_payload)
    if delta_payload is _OMIT:
        delta_payload = {}
    yaml_file_name = hostname + ".yaml"
    output_path = os.path.join(output_dir, "host_vars", yaml_file_name)
    write_yaml_file(output_path, {"jtaf_override": delta_payload})


def write_group_shared(output_dir: str, shared_payload: dict[str, Any]) -> None:
    """Write shared group vars defaults used by generated merge-aware role."""
    output_path = os.path.join(output_dir, "group_vars", "all.yml")
    write_yaml_file(output_path, {
        "jtaf_shared": shared_payload,
        "jtaf_list_merge": "replace",
    })


def main():
    parser = argparse.ArgumentParser(
        description='Generate Ansible hosts and host_vars YAML from XML using trimmed schema.',
        exit_on_error=True,
    )
    parser.add_argument(
        '-j',
        '--trimmed_json',
        required=True,
        help='Path to trimmed_schema.json generated by jtaf-provider/jtaf-yang2go.',
    )
    parser.add_argument(
        '-x',
        '--xml-config',
        required=True,
        nargs="+",
        help='One or more Junos XML config files to convert into host_vars YAML.',
    )
    parser.add_argument(
        '-d',
        '--directory',
        required=True,
        help='Output directory for hosts file and host_vars/*.yaml.',
    )
    parser.add_argument(
        '--extract-shared-group-vars',
        action='store_true',
        help='Write shared values to group_vars/all.yml and keep host_vars as per-host deltas.',
    )

    args = parser.parse_args()

    trimmed_json_file = args.trimmed_json
    xml_files = args.xml_config
    # --- Load JSON schema ---
    with open(trimmed_json_file, 'r') as f:
        schema = json.load(f)
    config_node = None
    for child in schema["root"]["children"]:
        if child["name"] == "configuration":
            config_node = child
            break
    if not config_node:
        raise ValueError("No configuration node found in JSON schema")

    directory = args.directory

    host_entries = []
    for xml_file in xml_files:
        host_entries.append(parse_xml_to_payload(xml_file, schema))

    host_payloads = [payload for _hostname, payload in host_entries]
    shared_payload = build_shared_payload(host_payloads) if args.extract_shared_group_vars else {}

    hostnames=[]
    for hostname, payload in host_entries:
        hostnames.append(hostname)
        write_host_override(directory, hostname, payload, shared_payload)

    if args.extract_shared_group_vars:
        write_group_shared(directory, shared_payload)
    
    with open(os.path.join(directory, "hosts"), "w") as f:
        f.write("[all]\n")
        for hostname in hostnames:
            f.write(f"{hostname}\n")

    


if __name__ == "__main__":
    main()
