#!/usr/bin/env python3
import argparse
import json
import os
from importlib.resources import as_file, files

from jinja2 import Template

from junosterraform.jtaf_common import filter_json_using_xml, load_and_merge_xmls


def main() -> None:
    """Generate an Ansible role/playbook from JTAF JSON schema and XML configuration.

    Parses command-line arguments for JSON schema (pyang output) and XML config files,
    filters schema to match config XPaths, renders Jinja2 templates, and generates a
    complete Ansible role structure with hierarchical variable merging support.

    Output directory structure:
        ansible-provider-junos-<type>/
            roles/<type>_role/
                tasks/main.yml
                templates/template.j2
            filter_plugins/
            group_vars/
            host_vars/
            configs/
            jtaf-playbook.yml
            trimmed_schema.json
    """
    # other arguments
    parser = argparse.ArgumentParser(
        description='Generate an Ansible role/playbook from JTAF JSON and XML config.',
        exit_on_error=True,
    )
    parser.add_argument(
        '-j',
        '--json-schema',
        required=True,
        help="Path to JTAF JSON schema, or '-' to read JSON from stdin.",
    )
    parser.add_argument(
        '-x',
        '--xml-config',
        required=True,
        action='append',
        nargs="+",
        help='One or more Junos XML config files to merge/filter against schema.',
    )
    parser.add_argument(
        '-t',
        '--type',
        required=True,
        help='Device type suffix used in output directory name.',
    )
    args = parser.parse_args()

    # Merge XML files if multiple are provided.
    xml_files = [file for group in args.xml_config for file in group]
    xml_config = xml_files[0] if len(xml_files) == 1 else load_and_merge_xmls(xml_files)

    # Step 1: Filter the schema using the config
    resources = filter_json_using_xml(args.json_schema, xml_config)

    # Step 2: Render the template into Jinja2 code
    with as_file(files('junosterraform').joinpath('__init__.py')) as init_py:
        package_dir = os.path.dirname(init_py)
    templates_dir = f"{package_dir}/templates"
    with open(f"{templates_dir}/ansible.j2") as f:
        jinja2_source = f.read()
    tmpl = Template(jinja2_source)
    rendered_lines = tmpl.render(data=resources).splitlines()
    resource_config_provider_j2 = "\n".join(
        line for line in rendered_lines if line.strip()
    )

    # Step 3: Prepare new output directory based on type
    new_dir = f"ansible-provider-junos-{args.type}"

    # Create roles/<rolename>/{tasks,templates} structure.
    role_name = f"{args.type}_role"
    roles_path = os.path.join(new_dir, "roles", role_name)
    tasks_path = os.path.join(roles_path, "tasks")
    templates_path = os.path.join(roles_path, "templates")
    os.makedirs(tasks_path, exist_ok=True)
    os.makedirs(templates_path, exist_ok=True)
    os.makedirs(os.path.join(new_dir, "host_vars"), exist_ok=True)
    os.makedirs(os.path.join(new_dir, "group_vars"), exist_ok=True)
    os.makedirs(os.path.join(new_dir, "configs"), exist_ok=True)

    # write a merge-aware tasks/main.yml
    tasks_main = """---
# Hierarchical variable merging with automatic device type detection.
# Merge order: global (all) -> device_type -> host
# with optional _merge_directive meta-instructions for custom behavior.

# Build the effective config from Ansible-resolved vars.
# Ansible already applies precedence across group_vars/host_vars; filter out
# runtime/meta keys that are not part of device configuration.
- name: Merge variables from hierarchy
  set_fact:
    jtaf_effective: >-
      {{{{
                vars
                | dict2items
                | rejectattr('key', 'match', '^(ansible_.*|inventory_.*|role_.*)$')
                | rejectattr('key', 'in', ['group_names', 'groups', 'group_vars', 'hostvars'])
                | rejectattr('key', 'in', ['omit', 'playbook_dir', 'tmp_dir', 'jtaf_effective'])
                | items2dict
      }}}}
  tags: [merge_vars]

# Handle _merge_directive meta-instructions for custom merge behavior
- name: Apply custom merge directives
  set_fact:
    jtaf_effective: "{{{{ jtaf_effective | jtaf_apply_merge_directives }}}}"
  when: jtaf_effective is defined
  tags: [merge_directives]

- name: Applying template for {role_name}
  template: src=template.j2 dest={{{{ tmp_dir }}}}/{{{{ inventory_hostname }}}}.xml
""".format(role_name=role_name)
    with open(os.path.join(tasks_path, "main.yml"), "w") as f:
        f.write(tasks_main)

    # write group_vars/all.yml — common defaults shared by all hosts
    group_vars_all = """# Common configuration for all hosts managed by this JTAF Ansible role.
# Values here are overridden by group_vars/device_<type>/all.yml, then host_vars/<host>.yml.
# No JTAF-specific wrapper containers are required.
"""
    with open(os.path.join(new_dir, "group_vars", "all.yml"), "w") as f:
        f.write(group_vars_all)

    # generate filter_plugins/jtaf_filters.py so the role's merge directives work
    filter_plugins_path = os.path.join(new_dir, "filter_plugins")
    os.makedirs(filter_plugins_path, exist_ok=True)
    with as_file(files('junosterraform').joinpath('templates/jtaf_filters.py')) as filters_src:
        with open(filters_src) as f:
            filters_content = f.read()
    with open(os.path.join(filter_plugins_path, "jtaf_filters.py"), "w") as f:
        f.write(filters_content)

    # copy rendered main.j2 into the role templates as an example
    with open(os.path.join(templates_path, "template.j2"), "w") as f:
        f.write(resource_config_provider_j2)

    # Step 4: Create a minimal ansible playbook
    playbook_content = f"""- name: Apply Junos configuration
  hosts: all
  connection: local
  gather_facts: no
  vars:
    tmp_dir: "configs"
  roles:
    - role: {role_name}
      delegate_to: localhost
"""
    with open(os.path.join(new_dir, "jtaf-playbook.yml"), "w") as f:
        f.write(playbook_content)

    # Step 5: Add trimmed_schema.json to new directory
    trimmed_schema_path = os.path.join(new_dir, "trimmed_schema.json")
    with open(trimmed_schema_path, "w") as f:
        json.dump(resources, f, indent=2)


if __name__ == "__main__":
    main()
